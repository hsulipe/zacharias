# Database
DATABASE_URL=postgresql://ged_user:ged_password@localhost:5432/ged_db

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=ged_minio_access
MINIO_SECRET_KEY=ged_minio_secret
MINIO_BUCKET=ged-documents
MINIO_USE_SSL=false

# JWT — CHANGE THESE IN PRODUCTION (min 32 chars each)
JWT_SECRET=change_me_in_production_jwt_secret_32chars
JWT_REFRESH_SECRET=change_me_in_production_refresh_secret

# CORS
CORS_ORIGIN=http://localhost:5173

# File limits
MAX_FILE_SIZE_MB=50

# Email (optional — leave blank to disable alerts)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@ged.local
